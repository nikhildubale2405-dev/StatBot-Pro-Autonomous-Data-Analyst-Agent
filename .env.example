APP_NAME=StatBot Pro
ENVIRONMENT=development
DATABASE_URL=sqlite:///data/db/statbot.db
DATA_DIR=data
FRONTEND_DIST_DIR=frontend/dist
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MAX_AGENT_RETRIES=2
MAX_UPLOAD_BYTES=26214400
AUTH_SECRET_KEY=change-this-to-a-long-random-secret
AUTH_TOKEN_EXPIRE_MINUTES=10080

SANDBOX_IMAGE=statbot-sandbox:latest
SANDBOX_MODE=local
SANDBOX_LOCAL_RUNNER_PATH=sandbox/runtime/runner.py
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_NANO_CPUS=1000000000
SANDBOX_TIMEOUT_SECONDS=25
